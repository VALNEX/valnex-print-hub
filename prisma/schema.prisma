generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  schemas  = ["platform", "catalog", "ops"]
}

//
// ENUMS
//

enum RecordStatus {
  active
  inactive
  suspended
  deleted

  @@schema("platform")
}

enum PrintDeviceType {
  thermal
  label
  laser
  inkjet
  dot_matrix
  mobile
  virtual
  other

  @@schema("catalog")
}

enum PrintConnectionType {
  network
  bluetooth
  usb
  serial
  bridge
  cloud
  spooler
  other

  @@schema("catalog")
}

enum PrintDeviceStatus {
  online
  offline
  busy
  error
  paused
  unknown

  @@schema("catalog")
}

enum PrintJobFormat {
  text
  escpos
  pdf
  image
  zpl
  raw
  html
  qrcode
  barcode

  @@schema("ops")
}

enum PrintJobPriority {
  low
  normal
  high
  critical

  @@schema("ops")
}

enum PrintJobStatus {
  queued
  routing
  processing
  sent
  printed
  failed
  cancelled
  retrying

  @@schema("ops")
}

enum PrintLogEvent {
  received
  validated
  rejected
  queued
  routing_resolved
  routing_failed
  assigned_printer
  sent_to_queue
  sent_to_bridge
  sent_to_printer
  printed
  failed
  retried
  cancelled

  @@schema("ops")
}

//
// MODELS
//

model Tenant {
  id             String      @id @default(uuid()) @db.Uuid
  name           String      @db.VarChar(150)
  slug           String      @unique @db.VarChar(100)
  legalName      String?     @db.VarChar(200)
  taxId          String?     @db.VarChar(50)
  apiKey         String?     @unique @db.VarChar(255)
  webhookSecret  String?     @db.VarChar(255)
  status         RecordStatus @default(active)
  timezone       String?     @db.VarChar(80)
  currency       String?     @db.VarChar(10)
  language       String?     @db.VarChar(10)
  logoUrl        String?     @db.Text
  metadata       Json?
  settings       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  locations      PrintLocation[]
  devices        PrintDevice[]
  sources        PrintSource[]
  routingRules   PrintRoutingRule[]
  jobs           PrintJob[]
  jobLogs        PrintJobLog[]

  @@index([status])
  @@index([createdAt])
  @@schema("platform")
  @@map("tenants")
}

model AdminUser {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique @db.VarChar(150)
  passwordHash String       @db.VarChar(255)
  fullName     String?      @db.VarChar(150)
  status       RecordStatus @default(active)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@schema("platform")
  @@map("admin_users")
}

model PrintLocation {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  name         String       @db.VarChar(150)
  code         String       @db.VarChar(80)
  description  String?      @db.Text
  addressLine1 String?      @db.VarChar(150)
  addressLine2 String?      @db.VarChar(150)
  city         String?      @db.VarChar(100)
  state        String?      @db.VarChar(100)
  country      String?      @db.VarChar(100)
  postalCode   String?      @db.VarChar(20)
  status       RecordStatus @default(active)
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  devices      PrintDevice[]
  routingRules PrintRoutingRule[]
  jobs         PrintJob[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, name])
  @@schema("catalog")
  @@map("print_locations")
}

model PrintDevice {
  id                String               @id @default(uuid()) @db.Uuid
  tenantId          String               @db.Uuid
  locationId        String?              @db.Uuid
  name              String               @db.VarChar(150)
  code              String               @db.VarChar(80)
  description       String?              @db.Text
  type              PrintDeviceType
  brand             String?              @db.VarChar(100)
  model             String?              @db.VarChar(100)
  connectionType    PrintConnectionType
  identifier        String               @db.VarChar(255)
  host              String?              @db.VarChar(255)
  port              Int?
  macAddress        String?              @db.VarChar(50)
  deviceSerial      String?              @db.VarChar(100)
  driverName        String?              @db.VarChar(100)
  paperWidthMm      Int?
  dpi               Int?
  isDefault         Boolean              @default(false)
  acceptsRaw        Boolean              @default(false)
  acceptsEscpos     Boolean              @default(false)
  acceptsZpl        Boolean              @default(false)
  acceptsPdf        Boolean              @default(false)
  acceptsImage      Boolean              @default(false)
  status            PrintDeviceStatus    @default(unknown)
  lastSeenAt        DateTime?
  metadata          Json?
  settings          Json?
  statusReason      String?              @db.Text
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?

  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  location          PrintLocation?       @relation(fields: [locationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  routingRules      PrintRoutingRule[]
  jobs              PrintJob[]

  @@unique([tenantId, code])
  @@unique([tenantId, identifier])
  @@index([tenantId])
  @@index([tenantId, locationId])
  @@index([tenantId, status])
  @@index([tenantId, isDefault])
  @@schema("catalog")
  @@map("print_devices")
}

model PrintSource {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @db.Uuid
  name         String       @db.VarChar(120)
  code         String       @db.VarChar(80)
  description  String?      @db.Text
  status       RecordStatus @default(active)
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  routingRules PrintRoutingRule[]
  jobs         PrintJob[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@schema("catalog")
  @@map("print_sources")
}

model PrintRoutingRule {
  id            String      @id @default(uuid()) @db.Uuid
  tenantId      String      @db.Uuid
  sourceId      String?     @db.Uuid
  locationId    String?     @db.Uuid
  printerId     String      @db.Uuid
  name          String      @db.VarChar(150)
  description   String?     @db.Text
  documentType  String      @db.VarChar(100)
  format        PrintJobFormat?
  priority      Int         @default(100)
  copies        Int?
  isActive      Boolean     @default(true)
  stopOnMatch   Boolean     @default(true)
  conditions    Json?
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  source        PrintSource?   @relation(fields: [sourceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  location      PrintLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  printer       PrintDevice    @relation(fields: [printerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, documentType])
  @@index([tenantId, sourceId, locationId, documentType, isActive])
  @@index([tenantId, priority])
  @@schema("ops")
  @@map("print_routing_rules")
}

model PrintJob {
  id                 String            @id @default(uuid()) @db.Uuid
  tenantId           String            @db.Uuid
  locationId         String?           @db.Uuid
  printerId          String?           @db.Uuid
  sourceId           String?           @db.Uuid
  routingRuleId      String?           @db.Uuid

  externalId         String?           @db.VarChar(120)
  requestId          String?           @db.VarChar(120)
  documentType       String            @db.VarChar(100)
  format             PrintJobFormat
  priority           PrintJobPriority  @default(normal)
  status             PrintJobStatus    @default(queued)

  copies             Int               @default(1)
  payload            Json
  renderedPayload    Json?
  contentHash        String?           @db.VarChar(128)

  printerCode        String?           @db.VarChar(80)
  locationCode       String?           @db.VarChar(80)
  sourceCode         String?           @db.VarChar(80)

  requestedBy        String?           @db.VarChar(150)
  requestedByUserId  String?           @db.Uuid
  requestedAt        DateTime          @default(now())
  queuedAt           DateTime?
  processingAt       DateTime?
  sentAt             DateTime?
  processedAt        DateTime?

  attempts           Int               @default(0)
  maxRetries         Int               @default(0)
  lastErrorCode      String?           @db.VarChar(80)
  errorMessage       String?           @db.Text

  bridgeNode         String?           @db.VarChar(120)
  ipAddress          String?           @db.VarChar(80)
  userAgent          String?           @db.Text

  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  cancelledAt        DateTime?
  deletedAt          DateTime?

  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  location           PrintLocation?    @relation(fields: [locationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  printer            PrintDevice?      @relation(fields: [printerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  source             PrintSource?      @relation(fields: [sourceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  logs               PrintJobLog[]

  @@unique([tenantId, externalId], map: "uq_print_jobs_tenant_external_id")
  @@unique([tenantId, requestId], map: "uq_print_jobs_tenant_request_id")
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority, status])
  @@index([tenantId, sourceId, status])
  @@index([tenantId, locationId, status])
  @@index([tenantId, printerId, status])
  @@index([tenantId, requestedAt])
  @@index([tenantId, documentType])
  @@schema("ops")
  @@map("print_jobs")
}

model PrintJobLog {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @db.Uuid
  jobId         String       @db.Uuid
  event         PrintLogEvent
  level         String?      @db.VarChar(20) // info, warn, error
  message       String?      @db.Text
  errorCode     String?      @db.VarChar(80)
  context       Json?
  createdAt     DateTime     @default(now())

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  job           PrintJob     @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([jobId])
  @@index([tenantId, event])
  @@index([tenantId, createdAt])
  @@schema("ops")
  @@map("print_job_logs")
}
